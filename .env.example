# ---- Supabase (client-side, safe to expose) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---- SerpAPI (server-side only, used by /api/trends) ----
SERPAPI_KEY=your-serpapi-key

# ---- OpenAI (server-side only, used by /api/agent) ----
OPENAI_API_KEY=sk-your-openai-key

# ---- Optional: enables search history persistence from the Next.js API route ----
# Find this in your Supabase dashboard under Project Settings → API → service_role key.
# Without it the dashboard still works, but searches won't be saved to Supabase.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Edge Function (alternative deployment) ----
# If you deploy the Supabase Edge Function instead of /api/trends, set the
# SerpAPI secret on Supabase directly:
#   supabase secrets set SERPAPI_KEY=your-serpapi-key
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically
# into Edge Functions by Supabase at runtime.
